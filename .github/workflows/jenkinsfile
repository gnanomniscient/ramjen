pipeline {
  agent any
  stages {
    stage('Checkout Code'){
      steps{
        git branch: 'main', url: 'https://github.com/parth2k3/test-flask.git'
      }
    }
    stage('Build'){
      steps{
         sh 'echo "building the app"'
       }
    }
    stage('Test'){
  steps {
    sh 'echo "Running tests"'
   }
  }
  stage('Deploy'){
    steps{
      sh 'echo "deploying"'
   }
  }
 }
}
 Post{
    success{
       bat 'echo "build successful"'
      }
      failure{
        bat 'echo "build failed"'
      }
    }
